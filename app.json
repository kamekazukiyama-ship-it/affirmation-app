{
  "expo": {
    "name": "AI×倍速×アファーメーション",
    "slug": "baisoku-affirmation",
    "version": "1.0.0",
    "sdkVersion": "52.0.0",
    "newArchEnabled": false,
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A1A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kazu.antigravity",
      "buildNumber": "1",
      "newArchEnabled": false,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "AIによるアファメーション音声合成（ボイスクローン）を作成するために、あなたの声を録音する目的でマイクを使用します。",
        "UIBackgroundModes": [
          "audio"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.kazu.antigravity",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0A0A1A",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "newArchEnabled": false,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "RECORD_AUDIO"
      ]
    },
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": [
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "0ecdfb70-4ba0-45fc-b144-c05d8025e275"
      }
    }
  }
}
