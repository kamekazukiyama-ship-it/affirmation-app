{
  "expo": {
    "name": "AI×倍速×アファメーション",
    "slug": "baisoku-affirmation",
    "version": "1.0.4",
    "sdkVersion": "52.0.0",
    "newArchEnabled": false,
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A1A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kazu.antigravity",
      "buildNumber": "18",
      "newArchEnabled": false,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "アファメーションのボイスクローンを作成するために、自分の声を録音する目的でマイクを使用します。録音された声はAI音声生成にのみ使用されます。",
        "NSPhotoLibraryUsageDescription": "お気に入りの写真をプレイヤー画面の背景に設定して、アファメーション体験をカスタマイズするために、写真アルバムへの読み取りアクセスを使用します。",
        "UIBackgroundModes": [
          "audio"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.kazu.antigravity",
      "versionCode": 8,
      "adaptiveIcon": {
        "backgroundColor": "#0A0A1A",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "newArchEnabled": false,
      "predictiveBackGestureEnabled": false,
      "blockedPermissions": [
        "android.permission.CAMERA"
      ],
      "permissions": [
        "RECORD_AUDIO"
      ]
    },
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": [
      [
        "react-native-google-mobile-ads",
        {
          "iosAppId": "ca-app-pub-6343618071277983~8462747901",
          "androidAppId": "ca-app-pub-3940256099942544~3347511713"
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          },
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0"
          }
        }
      ],
      "expo-localization"
    ],
    "extra": {
      "eas": {
        "projectId": "0ecdfb70-4ba0-45fc-b144-c05d8025e275"
      }
    }
  }
}
